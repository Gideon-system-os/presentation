// ── PORTAL TRANSITION ─────────────────────────────────────────
function triggerPortal(x, y, color, cb){
  const overlay = document.getElementById('portal-overlay');
  const ring    = document.getElementById('portal-ring');
  overlay.style.opacity='1';
  ring.style.cssText=`border-radius:50%;border:3px solid ${color};box-shadow:0 0 40px ${color},inset 0 0 40px ${color}33;width:0;height:0;position:absolute;left:${x}px;top:${y}px;transform:translate(-50%,-50%);transition:width .45s cubic-bezier(.4,0,.2,1),height .45s cubic-bezier(.4,0,.2,1),opacity .3s;opacity:1`;
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    ring.style.width='220vmax'; ring.style.height='220vmax';
    ring.style.opacity='0';
  }));
  setTimeout(()=>{ overlay.style.opacity='0'; cb(); ring.style.width='0'; ring.style.height='0'; }, 350);
}

