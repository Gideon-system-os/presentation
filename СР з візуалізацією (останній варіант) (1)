я<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Службові розслідування — Фрактальна Канбан</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: #0a0e1a;
    font-family: "Segoe UI", sans-serif;
    color: #e0e8ff;
    overflow: hidden;
    width: 100vw; height: 100vh;
  }
  #universe {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at 30% 40%, #0d1b3e 0%, #050810 60%);
    overflow: hidden;
  }
  .star { position:absolute; border-radius:50%; background:#fff; animation:twinkle var(--t,3s) ease-in-out infinite; }
  @keyframes twinkle { 0%,100%{opacity:.2} 50%{opacity:.9} }

  #navbar {
    position:fixed; top:0; left:0; right:0; z-index:1000;
    background:rgba(5,8,16,.85); backdrop-filter:blur(12px);
    border-bottom:1px solid rgba(100,160,255,.2);
    display:flex; align-items:center; gap:8px; padding:10px 18px; font-size:13px;
  }
  .breadcrumb { color:#5a90e8; cursor:pointer; }
  .breadcrumb:hover { color:#8ab8ff; text-decoration:underline; }
  .bc-sep { color:#334; }
  #back-btn {
    margin-left:auto; background:rgba(80,130,230,.25);
    border:1px solid rgba(80,130,230,.5); color:#8ab8ff;
    padding:5px 14px; border-radius:20px; cursor:pointer; font-size:12px; transition:all .2s;
  }
  #back-btn:hover { background:rgba(80,130,230,.45); }
  #back-btn:disabled { opacity:.3; cursor:default; }

  .view {
    position:fixed; inset:0;
    display:flex; align-items:center; justify-content:center;
    transition:opacity .5s, transform .5s; padding-top:50px;
  }
  .view.hidden { opacity:0; pointer-events:none; }
  .view.zoom-out { transform:scale(1.4); opacity:0; }
  .view.zoom-in  { transform:scale(.5);  opacity:0; }

  #galaxy-view .title {
    position:fixed; top:58px; left:50%; transform:translateX(-50%);
    font-size:18px; font-weight:700; color:#8ab8ff; letter-spacing:2px;
    text-shadow:0 0 20px rgba(100,160,255,.6); text-align:center; pointer-events:none;
    white-space:nowrap;
  }
  #galaxy-view .subtitle {
    position:fixed; top:84px; left:50%; transform:translateX(-50%);
    font-size:10px; color:#3a5a9a; letter-spacing:2px; pointer-events:none; white-space:nowrap;
  }

  .planet-wrap {
    position:absolute; cursor:pointer;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:5px; width:190px; height:190px;
    transition:transform .3s;
  }
  .planet-body {
    display:flex; flex-direction:column; align-items:center; gap:5px;
    pointer-events:none;
  }
  .planet-wrap:hover .planet {
    transform:scale(1.06);
    box-shadow:0 0 40px var(--glow,#4488ff),0 0 80px var(--glow2,#4488ff40) !important;
  }
  .planet-float {
    display:inline-flex; align-items:center; justify-content:center;
    transform-origin:center;
    will-change:transform;
  }
  .planet {
    border-radius:50%; background:var(--bg);
    box-shadow:0 0 20px var(--glow,#4488ff),inset 0 -8px 20px rgba(0,0,0,.4);
    transition:box-shadow .3s;
    display:flex; align-items:center; justify-content:center; font-size:56px;
    position:relative; overflow:hidden;
  }
  .planet::after { content:""; position:absolute; inset:-2px; border-radius:50%; border:2px solid rgba(255,255,255,.1); }
  .planet-label { font-size:16px; font-weight:700; color:#8ab8ff; text-align:center; max-width:140px; text-shadow:0 0 10px rgba(100,160,255,.5); }
  .planet-count { font-size:13px; color:#3a6090; }
  .orbit-ring { position:absolute; border-radius:50%; border:1px dashed rgba(255,255,255,.08); pointer-events:none; animation:orbit-spin 20s linear infinite; }
  @keyframes orbit-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  #system-view { flex-direction:column; padding:50px 0 0; }
  #system-title {
    position:fixed; top:58px; left:50%; transform:translateX(-50%);
    font-size:16px; font-weight:700; letter-spacing:2px;
    text-shadow:0 0 20px currentColor; pointer-events:none;
  }
  .solar-system { position:relative; width:min(92vw,820px); height:min(82vh,720px); }

  .sun-node {
    position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);
    width:160px; height:160px; border-radius:50%;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-size:48px; z-index:10; text-align:center; gap:4px;
    box-shadow:0 0 50px var(--color),0 0 100px var(--color2,#ff8800);
    background:radial-gradient(circle,var(--c1) 0%,var(--c2) 100%);
  }
  .sun-label { font-size:13px; font-weight:700; color:#fff; letter-spacing:1px; max-width:130px; text-align:center; line-height:1.3; }
  .orbit-path {
    position:absolute; left:50%; top:50%; border-radius:50%;
    border:1px dashed rgba(255,255,255,.1); pointer-events:none;
    transform:translate(-50%,-50%);
  }
  .satellite { position:absolute; cursor:pointer; transition:transform .25s; }
  .satellite:hover { transform:scale(1.18) !important; z-index:20; }
  .sat-body {
    border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:28px; position:relative;
    box-shadow:0 0 12px var(--sg,#4488ff); background:var(--sb); flex-shrink:0;
  }
  .sat-label-box {
    position:absolute; background:rgba(5,12,28,.95);
    border:1px solid rgba(100,160,255,.3); border-radius:8px; padding:7px 10px;
    font-size:14px; width:200px; pointer-events:none; z-index:30;
    box-shadow:0 4px 20px rgba(0,0,0,.7); line-height:1.5;
  }
  .stitle { font-weight:700; color:#8ab8ff; font-size:15px; margin-bottom:4px; }
  .sdesc { color:#5070a0; font-size:12px; }
  .satellite:hover .sat-label-box { display:block !important; }

  #detail-view { align-items:flex-start; justify-content:flex-start; padding:55px 0 0; overflow-y:auto; }
  .detail-panel { max-width:920px; width:95vw; margin:0 auto; padding:20px 20px 40px; }
  .detail-header { display:flex; align-items:center; gap:14px; margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid rgba(100,160,255,.2); }
  .detail-icon { font-size:48px; }
  .detail-title { font-size:26px; font-weight:700; color:#8ab8ff; }
  .detail-sub { font-size:15px; color:#3a6090; margin-top:4px; }

  .info-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; margin-bottom:16px; }
  .info-card { background:rgba(15,25,55,.7); border:1px solid rgba(60,100,200,.3); border-radius:12px; padding:16px; transition:border-color .2s,box-shadow .2s; }
  .info-card:hover { border-color:rgba(100,160,255,.5); box-shadow:0 4px 20px rgba(50,100,200,.2); }
  .card-head { font-size:14px; font-weight:700; color:#5a90d0; letter-spacing:1px; margin-bottom:10px; text-transform:uppercase; }
  .card-body { font-size:16px; color:#a0b8d8; line-height:1.8; }
  .card-body ul { padding-left:18px; }
  .card-body li { margin-bottom:7px; }

  .callout { background:rgba(200,80,30,.15); border-left:3px solid #e87030; border-radius:0 8px 8px 0; padding:12px 16px; margin:8px 0; font-size:16px; color:#e0a060; line-height:1.7; }
  .callout-blue { background:rgba(40,80,200,.15); border-left:3px solid #4080e0; border-radius:0 8px 8px 0; padding:12px 16px; margin:8px 0; font-size:16px; color:#80b0f0; line-height:1.7; }
  .section-div { border:none; border-top:1px solid rgba(100,160,255,.15); margin:14px 0; }

  .doc-gallery { display:flex; flex-wrap:wrap; gap:14px; margin-top:10px; }
  .doc-thumb { width:175px; border-radius:8px; overflow:hidden; border:1px solid rgba(100,160,255,.3); cursor:pointer; transition:transform .2s,box-shadow .2s; background:#0d1830; }
  .doc-thumb:hover { transform:scale(1.05); box-shadow:0 8px 30px rgba(50,100,200,.4); }
  .doc-thumb img { width:100%; height:215px; object-fit:cover; display:block; }
  .doc-cap { padding:7px 8px; font-size:11px; color:#5a80b0; text-align:center; }

  #lightbox { position:fixed; inset:0; z-index:2000; background:rgba(0,0,0,.93); display:flex; align-items:center; justify-content:center; cursor:zoom-out; }
  #lightbox.hidden { display:none; }
  #lightbox img { max-width:90vw; max-height:90vh; border-radius:8px; }

  /* ── NEW EFFECT ANIMATIONS ── */
  @keyframes planet-float-0 {
    0%   { transform: translateY(0px)   rotate(-1deg); }
    50%  { transform: translateY(-22px) rotate(1deg); }
    100% { transform: translateY(0px)   rotate(-1deg); }
  }
  @keyframes planet-float-1 {
    0%   { transform: translateY(4px)   rotate(1.5deg); }
    50%  { transform: translateY(-26px) rotate(-1deg); }
    100% { transform: translateY(4px)   rotate(1.5deg); }
  }
  @keyframes planet-float-2 {
    0%   { transform: translateY(-6px)  rotate(0.5deg); }
    50%  { transform: translateY(-28px) rotate(-1.5deg); }
    100% { transform: translateY(-6px)  rotate(0.5deg); }
  }
  @keyframes planet-float-3 {
    0%   { transform: translateY(2px)   rotate(-2deg); }
    50%  { transform: translateY(-20px) rotate(1.5deg); }
    100% { transform: translateY(2px)   rotate(-2deg); }
  }
  @keyframes planet-float-4 {
    0%   { transform: translateY(-3px)  rotate(1deg); }
    50%  { transform: translateY(-24px) rotate(-0.5deg); }
    100% { transform: translateY(-3px)  rotate(1deg); }
  }
  @keyframes planet-float-5 {
    0%   { transform: translateY(6px)   rotate(-1.5deg); }
    50%  { transform: translateY(-30px) rotate(2deg); }
    100% { transform: translateY(6px)   rotate(-1.5deg); }
  }
  @keyframes planet-float-6 {
    0%   { transform: translateY(-2px)  rotate(2deg); }
    50%  { transform: translateY(-18px) rotate(-1deg); }
    100% { transform: translateY(-2px)  rotate(2deg); }
  }
  @keyframes planet-float-7 {
    0%   { transform: translateY(5px)   rotate(-0.5deg); }
    50%  { transform: translateY(-25px) rotate(1.5deg); }
    100% { transform: translateY(5px)   rotate(-0.5deg); }
  }
  @keyframes planet-float-8 {
    0%   { transform: translateY(-4px)  rotate(1deg); }
    50%  { transform: translateY(-27px) rotate(-2deg); }
    100% { transform: translateY(-4px)  rotate(1deg); }
  }
  @keyframes sun-pulse {
    0%,100% { box-shadow: 0 0 50px var(--color), 0 0 100px var(--color2,#ff8800), 0 0 0px rgba(255,255,255,0); }
    50%      { box-shadow: 0 0 80px var(--color), 0 0 160px var(--color2,#ff8800), 0 0 40px rgba(255,255,255,0.08); }
  }
  @keyframes sat-spin {
    from { filter: brightness(1) drop-shadow(0 0 6px currentColor); }
    50%  { filter: brightness(1.25) drop-shadow(0 0 14px currentColor); }
    to   { filter: brightness(1) drop-shadow(0 0 6px currentColor); }
  }
  @keyframes icon-spin {
    0%   { transform: rotate(0deg) scale(1); }
    25%  { transform: rotate(8deg) scale(1.08); }
    75%  { transform: rotate(-8deg) scale(1.08); }
    100% { transform: rotate(0deg) scale(1); }
  }
  @keyframes orbit-spin { from{transform:translate(-50%,-50%) rotate(0deg)} to{transform:translate(-50%,-50%) rotate(360deg)} }

  /* glowing orbit paths */
  .orbit-path { box-shadow: 0 0 8px rgba(100,160,255,0.06); }

  /* card hover lift */
  .info-card { transition: border-color .2s, box-shadow .2s, transform .2s; }
  .info-card:hover { transform: translateY(-3px); }

  /* planet hover pulse ring */
  .planet-wrap:hover .planet::before {
    content:""; position:absolute; inset:-8px; border-radius:50%;
    border: 2px solid rgba(255,255,255,0.2);
    animation: ring-expand .6s ease-out forwards;
  }
  @keyframes ring-expand {
    from { transform:scale(1); opacity:.8; }
    to   { transform:scale(1.3); opacity:0; }
  }

  /* sparkle dots around satellite on hover */
  .satellite:hover .sat-body::after {
    content:"✦";
    position:absolute; top:-14px; left:50%; transform:translateX(-50%);
    font-size:12px; color:#fff; opacity:0.8;
    animation: sparkle-pop .4s ease-out;
  }
  @keyframes sparkle-pop {
    from { transform:translateX(-50%) translateY(4px) scale(0); opacity:1; }
    to   { transform:translateX(-50%) translateY(-4px) scale(1.2); opacity:0; }
  }

  /* aurora sweep on galaxy background */
  #galaxy-view::before {
    content:""; position:absolute; inset:0; pointer-events:none;
    background: conic-gradient(from 200deg at 50% 50%, transparent 0deg, rgba(60,100,200,0.04) 40deg, transparent 80deg);
    animation: aurora-sweep 18s linear infinite;
  }
  @keyframes aurora-sweep { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  /* detail view smooth scroll */
  #detail-view { scroll-behavior: smooth; }

  /* navbar glow on active breadcrumb */
  .breadcrumb:hover { text-shadow: 0 0 12px rgba(100,160,255,0.7); }

  /* ── CUSTOM CURSOR ── */
  * { cursor: none !important; }
  #cursor {
    position: fixed; pointer-events: none; z-index: 9999;
    width: 18px; height: 18px; border-radius: 50%;
    background: radial-gradient(circle, rgba(180,220,255,0.95) 0%, rgba(100,160,255,0.4) 60%, transparent 100%);
    transform: translate(-50%,-50%);
    transition: width .15s, height .15s, opacity .15s;
    mix-blend-mode: screen;
  }
  #cursor-trail {
    position: fixed; pointer-events: none; z-index: 9998;
    border-radius: 50%; transform: translate(-50%,-50%);
    background: transparent;
    border: 1.5px solid rgba(100,160,255,0.5);
    width: 36px; height: 36px;
    transition: left .12s ease-out, top .12s ease-out, width .2s, height .2s, border-color .3s;
  }
  #cursor.clicking { width: 28px; height: 28px; }

  /* ── SATURN RINGS on planets ── */
  .saturn-ring {
    position: absolute; left: 50%; top: 50%;
    border-radius: 50%;
    border: 3px solid transparent;
    pointer-events: none;
    transform: translate(-50%,-50%) rotateX(70deg);
    animation: saturn-rotate 6s linear infinite;
  }
  @keyframes saturn-rotate { from{transform:translate(-50%,-50%) rotateX(70deg) rotate(0deg)} to{transform:translate(-50%,-50%) rotateX(70deg) rotate(360deg)} }

  /* ── 3D TILT on hover ── */
  .planet-wrap { perspective: 600px; }
  .planet { transition: transform .2s ease, box-shadow .3s; transform-style: preserve-3d; }

  /* ── TYPEWRITER cursor blink ── */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .typewriter-cursor { display:inline-block; animation: blink .7s infinite; color:#8ab8ff; }

  /* ── PORTAL TRANSITION overlay ── */
  #portal-overlay {
    position: fixed; inset: 0; z-index: 1500; pointer-events: none;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
  }
  #portal-ring {
    border-radius: 50%; border: 3px solid rgba(100,180,255,0.8);
    box-shadow: 0 0 40px rgba(100,180,255,0.6), inset 0 0 40px rgba(100,180,255,0.2);
    width: 0; height: 0;
    transition: none;
  }

  /* ── DYNAMIC AURORA WAVES ── */
  #aurora-canvas {
    position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.55;
  }

  /* ── INTRO SCREEN ── */
  #intro-screen {
    position: fixed; inset: 0; z-index: 5000;
    background: #020408;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 16px;
  }
  #intro-screen.fade-out { animation: intro-fade 1.2s ease forwards; }
  @keyframes intro-fade { to { opacity: 0; pointer-events: none; } }
  .intro-logo {
    font-size: 56px; opacity: 0;
    animation: intro-item .8s .3s ease forwards;
  }
  .intro-title {
    font-size: 22px; font-weight: 700; letter-spacing: 4px; color: #8ab8ff;
    text-align: center; opacity: 0; text-shadow: 0 0 30px rgba(100,160,255,.8);
    animation: intro-item .8s .7s ease forwards;
  }
  .intro-sub {
    font-size: 12px; color: #3a6090; letter-spacing: 3px; opacity: 0;
    animation: intro-item .8s 1.1s ease forwards;
  }
  .intro-bar {
    width: 220px; height: 2px; background: rgba(100,160,255,.15);
    border-radius: 2px; overflow: hidden; opacity: 0;
    animation: intro-item .6s 1.4s ease forwards;
  }
  .intro-bar-fill {
    height: 100%; width: 0%; background: linear-gradient(90deg,#2244cc,#8ab8ff,#2244cc);
    animation: bar-load 1.8s 1.5s ease forwards;
  }
  @keyframes bar-load { to { width: 100%; } }
  @keyframes intro-item { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
  .intro-enter-btn {
    margin-top: 8px; opacity: 0;
    background: rgba(60,100,200,.3); border: 1px solid rgba(100,160,255,.5);
    color: #8ab8ff; padding: 10px 30px; border-radius: 24px;
    font-size: 14px; letter-spacing: 2px; cursor: none !important;
    animation: intro-item .8s 3.2s ease forwards;
    transition: background .2s, box-shadow .2s;
  }
  .intro-enter-btn:hover { background:rgba(60,100,200,.55); box-shadow:0 0 20px rgba(100,160,255,.4); }
</style>
</head>
<body>
<div id="intro-screen">
  <div class="intro-logo">🌌</div>
  <div class="intro-title">СЛУЖБОВІ РОЗСЛІДУВАННЯ<br>У НАЦІОНАЛЬНІЙ ПОЛІЦІЇ</div>
  <div class="intro-sub">ГУНП У ЧЕРКАСЬКІЙ ОБЛАСТІ</div>
  <div class="intro-bar"><div class="intro-bar-fill"></div></div>
  <button class="intro-enter-btn" onclick="startApp()">✦ УВІЙТИ У ВСЕСВІТ ✦</button>
</div>

<canvas id="aurora-canvas"></canvas>
<div id="cursor"></div>
<div id="cursor-trail"></div>
<div id="portal-overlay"><div id="portal-ring"></div></div>
<div id="universe"></div>
<div id="navbar">
  <span class="breadcrumb" onclick="goLevel(0)">🌌 Всесвіт</span>
  <span class="bc-sep" id="bc1" style="display:none"> › </span>
  <span class="breadcrumb" id="bc1t" style="display:none" onclick="goLevel(1)"></span>
  <span class="bc-sep" id="bc2" style="display:none"> › </span>
  <span id="bc2t" style="color:#c0d8f0;display:none"></span>
  <button id="back-btn" onclick="goBack()" disabled>← Назад</button>
</div>

<div class="view" id="galaxy-view">
  <div class="title">СЛУЖБОВІ РОЗСЛІДУВАННЯ У ПОЛІЦІЇ</div>
  <div class="subtitle">ГУНП У ЧЕРКАСЬКІЙ ОБЛАСТІ · ФРАКТАЛЬНА КАРТА ЗНАНЬ · НАТИСНІТЬ НА ПЛАНЕТУ</div>
  <div id="galaxy-canvas" style="position:relative;width:min(96vw,960px);height:min(84vh,740px)"></div>
</div>

<div class="view hidden" id="system-view">
  <div id="system-title"></div>
  <div class="solar-system" id="solar-canvas"></div>
</div>

<div class="view hidden" id="detail-view">
  <div class="detail-panel" id="detail-content"></div>
</div>

<div id="lightbox" class="hidden" onclick="closeLightbox()">
  <img id="lb-img" src="" alt="">
</div>

<script>
const IMGS = { nakazP1:"data:image/jpeg;base64,",
  nakazP2:"data:image/jpeg;base64,",
  vysnovokP1:"data:image/jpeg;base64,",
  vysnovokP2:"data:image/jpeg;base64," };

let currentLevel=0, currentPlanet=null, currentSat=null;

// ══════════════════════════════════════════════════════════════
// ── INTRO + START ─────────────────────────────────────────────
function startApp(){
  const intro = document.getElementById('intro-screen');
  intro.classList.add('fade-out');
  setTimeout(()=>{ intro.style.display='none'; playStarsBurst(); }, 1200);
}
function playStarsBurst(){
  document.querySelectorAll('.planet-wrap').forEach((pw,i)=>{
    pw.style.opacity='0';
    pw.style.transform='translate(-50%,-50%) scale(0)';
    pw.style.transition=`opacity .6s ${i*0.1}s, transform .7s ${i*0.1}s cubic-bezier(.34,1.56,.64,1)`;
    requestAnimationFrame(()=>requestAnimationFrame(()=>{
      pw.style.opacity='1';
      pw.style.transform='translate(-50%,-50%) scale(1)';
      setTimeout(()=>{ pw.style.transition=''; pw.style.transform='translate(-50%,-50%)'; }, 800+i*100);
    }));
  });
}

// ══════════════════════════════════════════════════════════════
// ── CUSTOM CURSOR ─────────────────────────────────────────────
const cursorEl = document.getElementById('cursor');
const trailEl  = document.getElementById('cursor-trail');
let mouseX=0, mouseY=0;
document.addEventListener('mousemove', e=>{
  mouseX=e.clientX; mouseY=e.clientY;
  cursorEl.style.left=mouseX+'px'; cursorEl.style.top=mouseY+'px';
  setTimeout(()=>{ trailEl.style.left=mouseX+'px'; trailEl.style.top=mouseY+'px'; }, 80);
});
document.addEventListener('mousedown', ()=>cursorEl.classList.add('clicking'));
document.addEventListener('mouseup',   ()=>cursorEl.classList.remove('clicking'));

// Change trail color when hovering interactive elements
document.addEventListener('mouseover', e=>{
  const isInteractive = e.target.closest('.planet-wrap,.satellite,.info-card,.doc-thumb,button,.breadcrumb');
  trailEl.style.borderColor = isInteractive ? 'rgba(200,240,255,0.9)' : 'rgba(100,160,255,0.5)';
  trailEl.style.width  = isInteractive ? '50px' : '36px';
  trailEl.style.height = isInteractive ? '50px' : '36px';
});

// ── CURSOR SPARKLE TRAIL ──────────────────────────────────────
const sparkCanvas = document.createElement('canvas');
sparkCanvas.style.cssText='position:fixed;inset:0;pointer-events:none;z-index:9990';
document.body.appendChild(sparkCanvas);
const spkCtx = sparkCanvas.getContext('2d');
function resizeSpark(){ sparkCanvas.width=innerWidth; sparkCanvas.height=innerHeight; }
window.addEventListener('resize', resizeSpark); resizeSpark();
const sparks=[];
document.addEventListener('mousemove', e=>{
  if(Math.random()<0.35){
    sparks.push({ x:e.clientX, y:e.clientY,
      vx:(Math.random()-.5)*2.5, vy:(Math.random()-.5)*2.5-1,
      life:1, r:Math.random()*2.5+1,
      hue: 200+Math.random()*60 });
  }
});
function animateSparks(){
  spkCtx.clearRect(0,0,sparkCanvas.width,sparkCanvas.height);
  for(let i=sparks.length-1;i>=0;i--){
    const s=sparks[i];
    s.x+=s.vx; s.y+=s.vy; s.life-=0.04; s.r*=0.95;
    if(s.life<=0){sparks.splice(i,1);continue;}
    spkCtx.globalAlpha=s.life*0.7;
    spkCtx.fillStyle=`hsl(${s.hue},100%,80%)`;
    spkCtx.beginPath(); spkCtx.arc(s.x,s.y,s.r,0,Math.PI*2); spkCtx.fill();
  }
  spkCtx.globalAlpha=1;
  requestAnimationFrame(animateSparks);
}
animateSparks();

